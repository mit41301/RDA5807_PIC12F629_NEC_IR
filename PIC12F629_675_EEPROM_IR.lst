  VALUE

0054   1C2B           00256     BTFSS  button, 0     ;Check the last bit of the 'button' register
0055   285A           00257     GOTO   DECREASE_VOLUME;If it's 0 (Down), go to 'DECREASE_VOLUME'
                      00258 
0056                  00259 INCREASE_VOLUME:        ;Otherwise start 'INCREASE_VOLUME'
0056   0AA7           00260     INCF   volume, F      ;Increment the 'volume' register
0057   1A27           00261     BTFSC  volume, 4     ;If bit 4 becomes set (volume = 0b10010000)
0058   03A7           00262     DECF   volume, F      ;then decrement the 'volume' to get 0b10001111
0059   285D           00263     GOTO   SET_VOLUME     ;and go to the 'SET_VOLUME' label
                      00264 
005A                  00265 DECREASE_VOLUME:        ;Decrease the volume here
005A   03A7           00266     DECF   volume, F      ;Decrement the 'volume' register
005B   1FA7           00267     BTFSS  volume, 7     ;If bit 7 becomes 0 (volume = 0b01111111)
005C   0AA7           00268     INCF   volume, F      ;then increment the 'volume' to get 0b10000000
                      00269 
005D                  00270 SET_VOLUME:               ;Set the radio volume
005D   20BA           00271     CALL   I2C_START      ;Issue I2C start condition
005E   3022           00272     MOVLW  0x22           ;Radio chip address for random writing is 0x22
005F   20C1           00273     CALL   I2C_WRITE_BYTE ;Write the radio address via I2C
0060   3005           00274     MOVLW  0x05           ;Set the register number to write to (0x05)
0061   20C1           00275     CALL   I2C_WRITE_BYTE ;And write it via I2C
0062   3088           00276     MOVLW  0x88           ;Set the high byte of 0x05 register (default value)
0063   20C1           00277     CALL   I2C_WRITE_BYTE ;And write it via i2C
0064   0827           00278     MOVF   volume, W      ;Set the 'volume' as low byte of 0x05 register
0065   20C1           00279     CALL   I2C_WRITE_BYTE ;And write it via I2C
0066   20BD           00280     CALL   I2C_STOP       ;Issue Stop condition
0067   1C2C           00281     BTFSS  startup, 0     ;If 'startup' is 0 (not startup condition)
0068   284D           00282     GOTO   BUTTONS_LOOP   ;Then return to the 'BUTTONS_LOOP' label
0069   102C           00283     BCF    startup, 0     ;Otherwise reset the 'startup' register
                      00284 ; bcf INTCON, GPIE ;3;-> ENABLE the GPIO port change interrupt
                      00285 ; bcf INTCON, GIE  ;7;-> ENABLE all interrupts
                      00286 ; clrf _ir_data
006A   2841           00287     GOTO   LOOP           ;And return to the 'LOOP' label
                      00288 
006B                  00289 CHANNEL_SEEK:             ;Here button is released and we check what to do
006B   08AA           00290     MOVF   count, F       ;Check if 'count' register is 0
006C   1D03           00291     BTFSS  STATUS, Z      ;If 'count' is not 0 (it was a long press)
006D   2881           00292     GOTO   SAVE_VOLUME    ;then go to the 'SAVE VOLUME' label
006E   01AD           00293     CLRF   timer          ;Otherwise (short press) we clear the 'timer'
006F   142E           00294     BSF    need_save, 0   ;And set the 'need_save' register
                      00295 
0070                  00296 CH_UP:
0070   20BA           00297     CALL I2C_START      ;Issue I2C Start condition
0071   3020           00298     MOVLW 0x20          ;Radio chip address for sequential writing is 0x20
0072   20C1           00299     CALL I2C_WRITE_BYTE ;Write the radio address via I2C
0073   1C2B           00300     BTFSS button, 0     ;Check the last bit of the 'button' register
0074   287B           00301     GOTO SEEK_DOWN      ;If it's 0 (button Down), go to 'SEEK_DOWN' label
0075   30C3           00302     MOVLW 0xC3          ;Otherwise set 0xC3 as high byte of 0x02 register
0076   20C1           00303     CALL I2C_WRITE_BYTE ;And write it via I2C
0077   3001           00304     MOVLW 0x01          ;Set 0x01 as low byte of 0x02 register
0078   20C1           00305     CALL I2C_WRITE_BYTE ;And write it via I2C
0079   20BD           00306     CALL I2C_STOP       ;Issue I2C Stop condition
                      00307 ; bcf INTCON, GPIE ;3;-> ENABLE the GPIO port change interrupt
                      00308 ; bcf INTCON, GIE  ;7;-> ENABLE all interrupts
MPASM  5.51       PIC12F629_675_EEPROM_IR.ASM   4-26-2026  19:56:06         PAGE  7


