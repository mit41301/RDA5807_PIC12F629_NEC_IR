                      00468 ;----------I2C send ACK----------------------
00E1                  00469 I2C_ACK:
00E1   20AE           00470     CALL SDA_LOW        ;Set SDA low to issue ACK condition
00E2   20B2           00471     CALL SCL_HIGH       ;Set SCL high to start the new pulse
00E3   20B6           00472     CALL SCL_LOW        ;Set SCL low to end the pulse
00E4   20AA           00473     CALL SDA_HIGH       ;Set SDA high to release the bus
00E5   3400           00474     RETLW 0
                      00475 ;----------I2C send NACK----------------------
00E6                  00476 I2C_NACK:
00E6   20AA           00477     CALL SDA_HIGH       ;Set SDA low to issue NACK condition
00E7   20B2           00478     CALL SCL_HIGH       ;Set SCL high to start the new pulse
00E8   20B6           00479     CALL SCL_LOW        ;Set SCL low to end the pulse
00E9   3400           00480     RETLW 0
                      00481 
                      00482 ;-------------Delay subroutine--------------
00EA                  00483 DELAY:                   ;Start DELAY subroutine here  
00EA   00A0           00484     MOVWF  DC1           ;Copy the value to the register i
00EB   00A1           00485     MOVWF  DC2           ;Copy the value to the register j
00EC                  00486 DELAY_LOOP:              ;Start delay loop
