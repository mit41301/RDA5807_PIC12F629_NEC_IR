00F0   0BA1           00491     DECFSZ DC2, F        ;Decrement j and check if it is not zero
00F1   28EC           00492     GOTO   DELAY_LOOP    ;If not, then go to the DELAY_LOOP label
00F2   3400           00493     RETLW  0             ;Else return from the subroutine
                      00494 ;------------------------------------------------------------------------------
