  VALUE

012F   0084           00574     MOVWF FSR            ;and save it to the indirect pointer register
0130                  00575 _RECEIVE_BYTE:
0130   01B1           00576     CLRF _bit_count      ;Clear the 'bit_count' register
0131   0180           00577     CLRF INDF            ;Clear the indirectly addressed register
0132                  00578 _RECEIVE_BIT:
0132   0C80           00579     RRF INDF, F          ;Shift the INDF register to the right
                      00580 ;---------------Receive the positive pulse of the bit-----------------
0133   0181           00581     CLRF TMR0           ;Otherwise clear the timer register
0134   1D85           00582     BTFSS GPIO, ir      ;And wait while 'ir' is low
0135   2934           00583     GOTO $-1
0136   0801           00584     MOVF TMR0, W        ;Copy the TMR0 value into the W register
0137   00AF           00585     MOVWF _count         ;and save the value into the 'count' register
0138   3001           00586     MOVLW 1             ;Load 1 into W (256 us x 1 = 0.26 ms)
0139   022F           00587     SUBWF _count, W      ;And subtract W from 'count'
013A   1C03           00588     BTFSS STATUS, C     ;If 'count' < 1 (pulse is shorter than 0.26 ms)
013B   2911           00589     GOTO _LOOP           ;then return to 'LOOP'
013C   3003           00590     MOVLW 3             ;Load 3 into W (256 us x 3 = 0.77 ms)
013D   022F           00591     SUBWF _count, W      ;And subtract W from 'count'
013E   1803           00592     BTFSC STATUS, C     ;If 'count' > 3 (pulse is longer than 0.77 ms)
013F   2911           00593     GOTO _LOOP           ;then return to 'LOOP'
                      00594 ;---------------Receive the negative pulse of the bit-----------------
0140   0181           00595     CLRF TMR0           ;Otherwise clear the timer register
0141   1985           00596     BTFSC GPIO, ir      ;And wait while 'ir' is high
0142   2941           00597     GOTO $-1
0143   0801           00598     MOVF TMR0, W        ;Copy the TMR0 value into the W register
0144   00AF           00599     MOVWF _count         ;and save the value into the 'count' register
0145   3004           00600     MOVLW 4;///////////             ;Load 5 into W (256 us x 4 = 1.1 ms)
0146   022F           00601     SUBWF _count, W      ;And subtract W from 'count'
0147   1C03           00602     BTFSS STATUS, C     ;If 'count' < 4 (pulse is shorter than 1.1 ms)
0148   294E           00603     GOTO _NEXT_BIT       ;then go to the 'NEXT_BIT' label
0149   3008           00604     MOVLW 8             ;Load 8 into W (256 us x 8 = 2 ms)
014A   022F           00605     SUBWF _count, W      ;And subtract W from 'count'
014B   1803           00606     BTFSC STATUS, C     ;If 'count' > 8 (pulse is longer than 2 ms)
014C   2911           00607     GOTO _LOOP           ;then go to the 'LOOP' label
014D   1780           00608     BSF INDF, 7         ;Set the MSB of the INDF register
014E                  00609 _NEXT_BIT:
014E   0AB1           00610     INCF   _bit_count, F   ;Increment the 'bit_count' register
014F   1DB1           00611     BTFSS  _bit_count, 3   ;Check if 'bit_count' becomes 8
0150   2932           00612     GOTO   _RECEIVE_BIT    ;If it's not, then return to 'RECEIVE_BIT' label
0151   0AB0           00613     INCF   _byte_count, F  ;Increment the 'byte_count' register
0152   1930           00614     BTFSC  _byte_count, 2  ;Check if 'byte_count' becomes 4    
0153   2956           00615     GOTO   _CHECK_DATA     ;If it is then go to 'CHECK_DATA' label
0154   0A84           00616     INCF   FSR, F          ;Increment the indirect addressing pointer
0155   2930           00617     GOTO   _RECEIVE_BYTE   ;and go to 'RECEIVE_BYTE' label
                      00618 
0156                  00619 _CHECK_DATA:
0156   0935           00620     COMF _ir_data+1, W   ;Negate the second received byte
0157   0634           00621     XORWF _ir_data, W    ;And implement the XOR between 1st and 2nd bytes
0158   1D03           00622     BTFSS STATUS, Z      ;If the result is not 0 (bytes are not equal)
0159   2911           00623     GOTO _LOOP           ;<--Then return to the 'LOOP' label
015A   0937           00624     COMF _ir_data+3, W   ;Negate the fourth received byte
015B   0636           00625     XORWF _ir_data+2, W  ;And implement the XOR between 3rd and 4th bytes
015C   1D03           00626     BTFSS STATUS, Z      ;If the result is not 0 (bytes are not equal)
