002C   210A           00203         call   READ_EEPROM    ;Read the Channel Frequency High Byte Info
002D   00A9           00204     movwf  frequency_h    ;and store its content into 'frequency_h'
                      00205 ;#######################################################################
                      00206 
002E   30C0           00207     MOVLW  0xC0           ;Implement AND operation between 0xC0
002F   05A8           00208     ANDWF  frequency_l, F ;and 'frequency_l' to clear its last 6 bits
0030   1628           00209     BSF    frequency_l, 4 ;Set bit 4 (Tune) to adjust the frequency
                      00210 
0031                  00211 START_RADIO:
                      00212                           ;Start FM radio
0031   20BA           00213     CALL   I2C_START      ;Issue I2C Start condition
0032   3020           00214     MOVLW  0x20           ;Radio chip address for sequential writing is 0x20
0033   20C1           00215     CALL   I2C_WRITE_BYTE ;Write the radio address via i2C
0034   30C0           00216     MOVLW  0xC0           ;Write high byte into radio register 0x02
0035   20C1           00217     CALL   I2C_WRITE_BYTE
0036   3001           00218     MOVLW  0x01           ;Write low byte into radio register 0x02
0037   20C1           00219     CALL   I2C_WRITE_BYTE
0038   0829           00220     MOVF   frequency_h, W ;Write high byte into radio register 0x03
0039   20C1           00221     CALL   I2C_WRITE_BYTE
003A   0828           00222     MOVF   frequency_l, W ;Write low byte into radio register 0x03
003B   20C1           00223     CALL   I2C_WRITE_BYTE
003C   20BD           00224     CALL   I2C_STOP       ;Issue I2C Stop condition
                      00225 
003D   300F           00226     MOVLW  0x0F         ;Implement AND operation between 0xC0
003E   05A7           00227     ANDWF  volume, F    ;and 'volume' to clear its higher 4 bits
003F   17A7           00228     BSF    volume, 7    ;Set bit 7  to select correct LNA input
0040   285D           00229     GOTO   SET_VOLUME   ;And go to the 'SET_VOLUME' label
                      00230 
0041                  00231 LOOP:                   ;Main loop of the program
                      00232                         ;Beginning of the button 1 checking
                      00233 ;// bsf INTCON, GPIE ;3;-> ENABLE the GPIO port change interrupt
                      00234 ;// bsf INTCON, GIE  ;7;-> ENABLE all interrupts
0041   20A5           00235     CALL   CHECK_BUTTONS  ;Read the buttons state
0042   3903           00236     ANDLW  3             ;Clear all the bits of the result except two LSBs
0043   1903           00237     BTFSC  STATUS, Z     ;If result is 0 (none of buttons were pressed)
0044   2884           00238     GOTO   WAIT_FOR_TIMER ;Then go to the 'WAIT_FOR_TIMER' label 
0045   3028           00239     MOVLW  .40            ;Otherwise load initial value for the delay  
0046   20EA           00240     CALL   DELAY          ;and perform the debounce delay
0047   20A5           00241     CALL   CHECK_BUTTONS  ;Then check the buttons state again
0048   3903           00242     ANDLW  3
0049   1903           00243     BTFSC  STATUS, Z     ;If result is 0 (none of buttons were pressed)
004A   2884           00244     GOTO   WAIT_FOR_TIMER ;Then go to the 'WAIT_FOR_TIMER' label
004B   00AB           00245     MOVWF  button        ;Save the W value into the 'button'
004C   01AA           00246     CLRF   count          ;clear loop counter
                      00247 
004D                  00248 BUTTONS_LOOP:           ;Loop while button is pressed
004D   30FF           00249     MOVLW  0xFF          ;Load initial value for the delay 200ms
004E   20EA           00250     CALL   DELAY          ;And perform the delay
004F   20A5           00251     CALL   CHECK_BUTTONS  ;Then check the buttons state again
0050   3903           00252     ANDLW  3
0051   1903           00253     BTFSC  STATUS, Z     ;If state is 0 (it was a short press)
0052   286B           00254     GOTO   CHANNEL_SEEK    ;Go to the 'CHANNEL_SEEK' label
0053   0AAA           00255     INCF   count, F       ;Otherwise (long press) increment the counter
MPASM  5.51       PIC12F629_675_EEPROM_IR.ASM   4-26-2026  19:56:06         PAGE  6


