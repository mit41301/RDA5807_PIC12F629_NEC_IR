  VALUE

                      00309 ; clrf _ir_data
007A   2884           00310     GOTO WAIT_FOR_TIMER ;And go to the 'WAIT_FOR_TIMER' label
                      00311 
007B                  00312 SEEK_DOWN:              ;Seek the station down
007B   30C1           00313     MOVLW 0xC1          ;Set 0xC1 as high byte of 0x02 register
007C   20C1           00314     CALL I2C_WRITE_BYTE ;Ending of previous transaction
007D   3001           00315     MOVLW 0x01          ;Set 0x01 as low byte of 0x02 register
007E   20C1           00316     CALL I2C_WRITE_BYTE ;And write it via I2C
007F   20BD           00317     CALL I2C_STOP       ;Issue I2C Stop condition
0080   2884           00318     GOTO WAIT_FOR_TIMER ;And go to the 'WAIT_FOR_TIMER' label
                      00319 ;####################################################################
                      00320 
0081                  00321 SAVE_VOLUME:
0081   01A6           00322         clrf   Loc_Ptr        ;ADDRESS to 0x00
0082   0827           00323         MOVFW  volume         ;Move Volume value to W Register
0083   20F3           00324         call   WRITE_EEPROM   ;Write current Volume into EEPROM
                      00325 ;####################################################################
                      00326 
0084                  00327 WAIT_FOR_TIMER:           ;Wait for 10 second to save the channel to EEPROM
0084   302D           00328     MOVLW  45             ;Set the delay about 40 ms
0085   20EA           00329     CALL   DELAY          ;And call the DELAY subroutine
0086   0FAD           00330     INCFSZ timer, F       ;Increase the 'timer' and check while it becomes 0
0087   2841           00331     GOTO   LOOP           ;If it's not 0 then return to the 'LOOP' label
                      00332 
0088   1C2E           00333     BTFSS  need_save, 0   ;Otherwise check the 'need_save' register
0089   2841           00334     GOTO   LOOP           ;If it's 0 then return to the 'LOOP' register
008A   102E           00335     BCF    need_save, 0   ;Otherwise clear the 'need_save' register
008B   20BA           00336     CALL   I2C_START      ;Issue I2C start condition
008C   3022           00337     MOVLW  0x22           ;Set the radic chip address for random writing
008D   20C1           00338     CALL   I2C_WRITE_BYTE ;And write it via I2C
008E   3003           00339     MOVLW  0x03           ;Set the radio register to read from (0x03)
008F   20C1           00340     CALL   I2C_WRITE_BYTE ;And write it via I2C
0090   20BA           00341     CALL   I2C_START      ;Issue I2C Repeated start condition
0091   3023           00342     MOVLW  0x23           ;Set the radio chip address for random reading
0092   20C1           00343     CALL   I2C_WRITE_BYTE ;And write it via I2C
0093   20D5           00344     CALL   I2C_READ_BYTE  ;Read the high byte of the register 0x03
0094   20E1           00345     CALL   I2C_ACK        ;Issue the Acknowledgement
0095   0823           00346     MOVF   i2c_data, W    ;Copy the 'i2c_data' content into W register
0096   00A9           00347     MOVWF  frequency_h    ;And save it to the 'frequency_h' register
0097   20D5           00348     CALL   I2C_READ_BYTE  ;Read the low byte of the register 0x03
0098   20E6           00349     CALL   I2C_NACK       ;Issue the Not acknowledgement
0099   0823           00350     MOVF   i2c_data, W    ;Copy the 'i2c_data' content into W register
009A   00A8           00351     MOVWF  frequency_l    ;And save it to the 'frequency_l' register
009B   20BD           00352     CALL   I2C_STOP       ;Issue I2C stop condition
                      00353 ;#############################################################################
                      00354 
009C                  00355 SAVE_CH:
009C   01A6           00356         clrf   Loc_Ptr            ;0x00
009D   0AA6           00357         incf   Loc_Ptr,f          ;0x01
009E   0828           00358         MOVF   frequency_l,W  ;0x01
009F   20F3           00359         call   WRITE_EEPROM
00A0   0AA6           00360         incf   Loc_Ptr,f          ;0x02
00A1   13A9           00361         BCF    frequency_h,7
