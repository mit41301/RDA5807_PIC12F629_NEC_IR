                      00534 ;##############################################################################
0111                  00535 IR_Rx:      ;---IR REMOTE CONTROL 38kHz ROUTINE--------------------------------
                      00536 ;##############################################################################
                      00537 
0111                  00538 _LOOP:                    ;Main loop of the program
                      00539 ;---------------Wait for the preamble positive pulse---------------------
0111   1985           00540     BTFSC GPIO, ir       ;Wait while 'ir' pin goes down
0112   2911           00541     GOTO _LOOP           ;If it's high then return to 'LOOP'
                      00542 ;///    GOTO CONTINUE ; //LOOP           ;If it's high then return to 'LOOP'
0113                  00543 INT_JMP:
0113   0181           00544     CLRF  TMR0           ;Otherwise clear the timer register
0114   1D85           00545     BTFSS GPIO, ir       ;And wait while 'ir' is low
0115   2914           00546     GOTO  $-1
0116   0801           00547     MOVF  TMR0, W        ;Copy the TMR0 value into the W register
0117   00AF           00548     MOVWF _count         ;and save the value into the 'count' register
0118   301E           00549     MOVLW d'30'          ;Load 30 into W (256 us x 32 = 7.7 ms)
0119   022F           00550     SUBWF _count, W      ;And subtract W from 'count'
011A   1C03           00551     BTFSS STATUS, C      ;If 'count' < 30 (pulse is shorter than 7.7 ms)
011B   2911           00552     GOTO  _LOOP          ;then return to 'LOOP'
011C   302D           00553     MOVLW d'45'          ;Load 45 into W (256 us x 45 = 11.5 ms)
011D   022F           00554     SUBWF _count, W      ;And subtract W from 'count'
011E   1803           00555     BTFSC STATUS, C      ;If 'count' > 45 (pulse is longer than 8 ms)
011F   2911           00556     GOTO _LOOP           ;then return to 'LOOP'
                      00557 ;---------------Check the preamble negative pulse---------------------
0120   0181           00558     CLRF TMR0            ;Otherwise clear the timer register
0121   1985           00559     BTFSC GPIO, ir       ;And wait while 'ir' is high
0122   2921           00560     GOTO $-1
0123   0801           00561     MOVF TMR0, W         ;Copy the TMR0 value into the W register
0124   00AF           00562     MOVWF _count         ;and save the value into the 'count' register
0125   300D           00563     MOVLW d'13'          ;Load 15 into W (256 us x 13 = 3.3 ms)
0126   022F           00564     SUBWF _count, W      ;And subtract W from 'count'
0127   1C03           00565     BTFSS STATUS, C      ;If 'count' < 13 (pulse is shorter than 3.3 ms)
0128   2911           00566     GOTO _LOOP           ;then return to 'LOOP'
0129   3014           00567     MOVLW d'20'          ;Load 20 into W (256 us x 20 = 5.1 ms)
012A   022F           00568     SUBWF _count, W      ;And subtract W from 'count'
012B   1803           00569     BTFSC STATUS, C      ;If 'count' > 20 (pulse is longer than 5.1 ms)
012C   2911           00570     GOTO _LOOP           ;then return to 'LOOP'
                      00571 ;---------------Receive the command bytes-----------------------------
012D   01B0           00572     CLRF _byte_count     ;Clear the 'byte_count' register    
012E   3034           00573     MOVLW _ir_data       ;Load the address of the 'ir_data' into W
MPASM  5.51       PIC12F629_675_EEPROM_IR.ASM   4-26-2026  19:56:06         PAGE 12


