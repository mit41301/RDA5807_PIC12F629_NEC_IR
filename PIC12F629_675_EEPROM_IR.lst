                      00415 ;-------------I2C start condition--------------
00BA                  00416 I2C_START:
00BA   20B2           00417     CALL SCL_HIGH       ;Set SCL high
00BB   20AE           00418     CALL SDA_LOW        ;Then set SDA low
00BC   3400           00419     RETLW 0
                      00420 ;-------------I2C stop condition---------------
00BD                  00421 I2C_STOP:
00BD   20AE           00422     CALL SDA_LOW        ;Set SDA low
00BE   20B2           00423     CALL SCL_HIGH       ;Set SCL high
00BF   20AA           00424     CALL SDA_HIGH       ;Then set SDA highs and release the bus
00C0   3400           00425     RETLW 0
                      00426 ;------------I2C write byte--------------------
00C1                  00427 I2C_WRITE_BYTE:
00C1   00A3           00428     MOVWF i2c_data      ;Load 'i2c_data' from W register
00C2   3008           00429     MOVLW 8             ;Load value 8 into 'bit_count'
00C3   00A2           00430     MOVWF bit_count     ;to indicate we're going to send 8 bits
00C4                  00431 I2C_WRITE_BIT:          ;Write single bit to I2C
00C4   20B6           00432     CALL SCL_LOW        ;Set SCL low, now we can change SDA
00C5   1FA3           00433     BTFSS i2c_data, 7   ;Check the MSB of 'i2c_data'
00C6   28C9           00434     GOTO I2C_WRITE_0    ;If it's 0 then go to the 'I2C_WRITE_0' label
00C7                  00435 I2C_WRITE_1:            ;Else continue with 'I2C_WRITE_1'
00C7   20AA           00436     CALL SDA_HIGH       ;Set SDA high
00C8   28CA           00437     GOTO I2C_SHIFT      ;And go to the 'I2C_SHIFT' label
00C9                  00438 I2C_WRITE_0:
00C9   20AE           00439     CALL SDA_LOW        ;Set SDA low
00CA                  00440 I2C_SHIFT:
00CA   20B2           00441     CALL SCL_HIGH       ;Set SCL high to start the new pulse
00CB   0DA3           00442     RLF i2c_data, F     ;Shift 'i2c_data' one bit to the left
00CC   0BA2           00443     DECFSZ bit_count, F ;Decrement the 'bit_count' value, check if it's 0
00CD   28C4           00444     GOTO I2C_WRITE_BIT  ;If not then return to the 'I2C_WRITE_BIT'
00CE                  00445 I2C_CHECK_ACK:          ;Else check the acknowledgement bit
00CE   20B6           00446     CALL SCL_LOW        ;Set I2C low to end the last pulse
00CF   20AA           00447     CALL SDA_HIGH       ;Set SDA high to release the bus
00D0   20B2           00448     CALL SCL_HIGH       ;Set I2C high to start the new pulse
00D1   0805           00449     MOVF GPIO, W        ;Copy the GPIO register value into the 'ack'
00D2   00A5           00450     MOVWF ack           ;Now bit 'sda' of the 'ack' will contain ACK bit
00D3   20B6           00451     CALL SCL_LOW        ;Set SCL low to end the acknowledgement bit
00D4   3400           00452     RETLW 0
                      00453 ;------------I2C read byte--------------------
00D5                  00454 I2C_READ_BYTE:
00D5   3008           00455     MOVLW 8             ;Load value 8 into 'bit_count'
00D6   00A2           00456     MOVWF bit_count     ;to indicate we're going to receive 8 bits
00D7   01A3           00457     CLRF i2c_data       ;Clear the 'i2c_data' register
00D8                  00458 I2C_READ_BIT:           ;Read single bit from the I2C
00D8   0DA3           00459     RLF i2c_data, F     ;Shift the 'i2c_data' register one bit to the left
00D9   20B6           00460     CALL SCL_LOW        ;Set SCL low to prepare for the new bit
00DA   20B2           00461     CALL SCL_HIGH       ;Set SCL high to read the bit value
00DB   1A85           00462     BTFSC GPIO, sda     ;Check the 'sda' bit in the GPIO register
00DC   1423           00463     BSF i2c_data, 0     ;if it's 1 then set the LSB of the 'i2c_data'
00DD   0BA2           00464     DECFSZ bit_count, F ;Decrement the 'bit_count' value, check if it's 0
00DE   28D8           00465     GOTO I2C_READ_BIT   ;If not, then return to the 'I2C_READ_BIT'
00DF   20B6           00466     CALL SCL_LOW        ;Set SCL low to end the last pulse
00E0   3400           00467     RETLW 0             ;Otherwise return from the subroutine
