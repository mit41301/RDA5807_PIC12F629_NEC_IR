                      00367 ;-------------Check buttons---------------
00A5                  00368 CHECK_BUTTONS:
                      00369 ;#############################################################
                      00370 ;INTCON - INTERRUPT CONTROL REGISTER (ADDRESS: 0Bh OR 8Bh)
                      00371 ;       bsf INTCON, GPIE ;3;-> ENABLE the GPIO port change interrupt
                      00372 ;       bsf INTCON, GIE  ;7;-> ENABLE all interrupts
                      00373 ;       bcf INTCON, PEIE ;6;   Disables all peripheral interrupts
                      00374 ;       bcf INTCON, T0IE ;5;   Disables the TMR0 interrupt
                      00375 ;       bcf INTCON, INTE ;4;   Disables the GP2/INT external interrupt
                      00376 ;       bsf INTCON, GPIE ;3;-> ENABLE the GPIO port change interrupt
                      00377 ;bcf INTCON, T0IF ;2; TMR0 register did not overflow
                      00378 ;#############################################################
                      00379 
                      00380 
00A5   1C05           00381     BTFSS GPIO, but_up  ;Check if button Up is pressed
00A6   3401           00382     RETLW 1             ;and return 1 (b'01')
00A7   1C85           00383     BTFSS GPIO, but_down;Check if button Down is pressed
00A8   3402           00384     RETLW 2             ;and return 2 (b'10')
                      00385 ;// goto _LOOP ;///140522////////
                      00386 ;//CONTINUE:
                      00387 ; btfss GPIO, GP3
                      00388 ; goto IR_Rx
00A9   3400           00389     RETLW 0             ;If none of buttons is pressed then return 0
                      00390 ;-------------Helper subroutines---------------
00AA                  00391 SDA_HIGH:               ;Set SDA pin high
00AA   16A4           00392     BSF port, sda       ;Set 'sda' bit in the 'port' to make it input
00AB   0824           00393     MOVF port, W        ;Copy 'port' into W register
00AC   0065           00394     TRIS GPIO           ;And set it as TRISGPIO value
00AD   3400           00395     RETLW 0
                      00396 
00AE                  00397 SDA_LOW:                ;Set SDA pin low
00AE   12A4           00398     BCF port, sda       ;Reset 'sda' bit in the 'port' to make it output
00AF   0824           00399     MOVF port, W        ;Copy 'port' into W register
00B0   0065           00400     TRIS GPIO           ;And set it as TRISGPIO value
00B1   3400           00401     RETLW 0
                      00402 
00B2                  00403 SCL_HIGH:               ;Set SCL pin high
